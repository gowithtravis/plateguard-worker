# === Supabase ===
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_SERVICE_KEY=eyJ...        # service_role key (bypasses RLS)
SUPABASE_ANON_KEY=eyJ...           # anon key (for client-side reference)

# === Browserbase (Cambridge eTIMS — cloud browser for Playwright) ===
BROWSERBASE_API_KEY=
BROWSERBASE_PROJECT_ID=
# === 2Captcha (Cambridge eTIMS image CAPTCHA) ===
TWOCAPTCHA_API_KEY=
# If Browserbase or 2Captcha vars are unset, Cambridge (eTIMS) checks are skipped (RMC cities still run).

# === Worker Config ===
WORKER_API_KEY=your-secret-key     # protects the /api endpoints
BROWSER_MODE=local                 # "local" or "browserbase"
CHECK_INTERVAL_HOURS=6             # how often to check plates
MAX_CONCURRENT_CHECKS=5            # parallel plate checks
REQUEST_DELAY_SECONDS=2            # delay between portal requests

# === Alert Config (Phase 1) ===
RESEND_API_KEY=                    # Resend for transactional email
ALERT_FROM_EMAIL=alerts@alerts.plateguard.io

# === Stripe (app.plateguard.io checkout & billing portal) ===
STRIPE_SECRET_KEY=sk_live_...      # or sk_test_... for testing
STRIPE_WEBHOOK_SECRET=whsec_...    # signing secret from Stripe Dashboard → Webhooks

# === Environment ===
ENVIRONMENT=development            # development | staging | production
LOG_LEVEL=INFO
PORT=8000

